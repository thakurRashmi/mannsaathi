# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so secrets never get committed.

# ---- AI provider ----
# Which provider to use: "ollama" (local, default) or "gemini" (cloud).
# Ollama is privacy-first and works offline — good fit for mental wellness.
LLM_PROVIDER=ollama

# ---- Ollama (local LLM) ----
# Default URL when running via docker-compose. The Ollama daemon runs on the
# host Mac (`brew services start ollama`); host.docker.internal points back
# to the host from inside the backend container.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Model to use. Pull it first with: `ollama pull gemma2:2b`
OLLAMA_MODEL=gemma2:2b

# ---- Gemini (cloud LLM, optional) ----
# Only used when LLM_PROVIDER=gemini. Get a free key at:
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# ---- Backend ----
BACKEND_PORT=8000
LOG_LEVEL=INFO

# CORS: comma-separated list of allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Where the frontend should call the backend.
NEXT_PUBLIC_API_URL=http://localhost:8000
