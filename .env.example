# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so secrets never get committed.

# ---- AI provider ----
# Get a free Gemini API key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Which model to use. Gemini 2.0 Flash is fast + free.
GEMINI_MODEL=gemini-2.0-flash-exp

# ---- Backend ----
BACKEND_PORT=8000
LOG_LEVEL=INFO

# CORS: comma-separated list of allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Where the frontend should call the backend.
# In docker-compose, "backend" resolves to the backend container.
# In the browser, we use localhost:8000 because the browser runs outside docker.
NEXT_PUBLIC_API_URL=http://localhost:8000
